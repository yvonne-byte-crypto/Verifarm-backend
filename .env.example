# Helius RPC (get a free key at helius.dev)
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Solana network
ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
ANCHOR_WALLET=~/.config/solana/id.json

# Trusted oracle keypair (AI risk scoring service)
# Generate with: solana-keygen new -o oracle-keypair.json
ORACLE_KEYPAIR_PATH=./oracle-keypair.json

# USDC devnet mint
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Bubblegum merkle tree (create with createTree from @metaplex-foundation/mpl-bubblegum)
MERKLE_TREE_ADDRESS=

# Optional: field officer registry admin keypair
ADMIN_KEYPAIR_PATH=./admin-keypair.json
